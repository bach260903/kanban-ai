# Backend-only template (optional). Prefer repository root `.env` — `app/config.py`
# loads `../.env` then `backend/.env` when cwd is `backend/`.
#
# Required for Settings (see app/config.py):
DATABASE_URL=postgresql+asyncpg://neo_kanban:change_me@localhost:5432/neo_kanban
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace_with_a_long_random_string
# Groq LLM — https://console.groq.com/keys
GROQ_API_KEY=
# Optional: default llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
SANDBOX_ROOT=../sandbox

# AI CLI Backends (add as needed)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CLI_PATH=gemini
CLAUDE_CODE_PATH=claude
