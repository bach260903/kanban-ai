# Backend-only template (optional). Prefer repository root `.env` — `app/config.py`
# loads `../.env` then `backend/.env` when cwd is `backend/`.
#
# Required for Settings (see app/config.py):
DATABASE_URL=postgresql+asyncpg://neo_kanban:change_me@localhost:5432/neo_kanban
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace_with_a_long_random_string
JWT_SECRET_KEY=change-me-in-production-min-32-chars
GITHUB_ENCRYPTION_KEY=optional-aes-key-for-pat-encryption
# Groq LLM — https://console.groq.com/keys
GROQ_API_KEY=
# Optional: default llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: dedicated model for the coder agent (more reliable tool calling)
# Recommended: llama3-groq-70b-8192-tool-use-preview
CODER_GROQ_MODEL=
SANDBOX_ROOT=../sandbox
# Per-agent LLM (google | groq)
CODER_LLM_PROVIDER=groq
ARCHITECT_LLM_PROVIDER=groq
REVIEW_LLM_PROVIDER=groq
# Optional Google Gemini when *_LLM_PROVIDER=google
# GOOGLE_API_KEY=

# AI CLI backends (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CLI_PATH=gemini
CLAUDE_CODE_PATH=claude

# Local UI: allow POST /api/v1/dev/token (frontend /dev/auth page)
DEV_AUTH_ENABLED=true
