# Neo-Kanban — local development template
# Copy this file to .env and fill in the values (never commit .env)

# --- Docker Compose (host port mapping) ---
POSTGRES_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379
BACKEND_PUBLISH_PORT=8000

# --- PostgreSQL (must match docker-compose postgres service) ---
POSTGRES_USER=neo_kanban
POSTGRES_PASSWORD=change_me_in_dotenv
POSTGRES_DB=neo_kanban

# --- Backend (FastAPI) — used when the API runs on the host (not inside Docker) ---
DATABASE_URL=postgresql+asyncpg://neo_kanban:change_me_in_dotenv@localhost:5432/neo_kanban
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=replace_with_a_long_random_string

# Per-agent LLM (google | groq) — default: all Groq
CODER_LLM_PROVIDER=groq
ARCHITECT_LLM_PROVIDER=groq
REVIEW_LLM_PROVIDER=groq

# Groq LLM — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional Google Gemini — only if you set *_LLM_PROVIDER=google
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash
# GOOGLE_API_MIN_INTERVAL_SECONDS=12
# GOOGLE_API_MAX_RETRIES=4

# AI CLI backends (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CLI_PATH=gemini
CLAUDE_CODE_PATH=claude

# Agent sandbox (relative to backend/ when running with uvicorn)
SANDBOX_ROOT=./sandbox

# Local UI: allow POST /api/v1/dev/token (frontend /dev/auth page)
DEV_AUTH_ENABLED=true

# Optional: comma-separated origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
